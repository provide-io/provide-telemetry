{
  "name": "@provide-io/telemetry",
  "version": "0.4.2",
  "description": "Structured logging, OTEL traces/metrics for TypeScript frontends — parity with provide.telemetry Python package",
  "license": "Apache-2.0",
  "author": "MindTenet LLC",
  "homepage": "https://github.com/provide-io/provide-telemetry#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/provide-io/provide-telemetry.git",
    "directory": "typescript"
  },
  "keywords": [
    "telemetry",
    "observability",
    "opentelemetry",
    "otel",
    "tracing",
    "metrics",
    "logging",
    "structlog",
    "pino",
    "w3c-traceparent"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./otel": {
      "types": "./dist/otel.d.ts",
      "browser": "./dist/otel-noop.js",
      "default": "./dist/otel.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint src tests --max-warnings=0",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "test:memory": "npx tsx scripts/memory-audit.ts",
    "prepublishOnly": "npm run build && npm run test:coverage"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "pino": "^10.3.1"
  },
  "peerDependencies": {
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api-logs": {
      "optional": true
    },
    "@opentelemetry/context-async-hooks": {
      "optional": true
    },
    "@opentelemetry/exporter-logs-otlp-http": {
      "optional": true
    },
    "@opentelemetry/exporter-metrics-otlp-http": {
      "optional": true
    },
    "@opentelemetry/exporter-trace-otlp-http": {
      "optional": true
    },
    "@opentelemetry/resources": {
      "optional": true
    },
    "@opentelemetry/sdk-logs": {
      "optional": true
    },
    "@opentelemetry/sdk-metrics": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-base": {
      "optional": true
    },
    "react": {
      "optional": false
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opentelemetry/context-async-hooks": "^2.6.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.0.0",
    "fast-check": "^4.6.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.8",
    "prettier": "^3.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.3.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
